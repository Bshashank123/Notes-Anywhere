{
  "manifest_version": 3,
  "name": "Notes — Anywhere",
  "version": "1.0.0",
  "description": "Beautiful floating notes. Anywhere on the web. Apple-grade polish.",
  "permissions": ["storage", "activeTab"],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+N",
        "mac": "Command+Shift+N"
      },
      "description": "Toggle Notes — Anywhere panel"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Notes — Anywhere",
    "default_icon": {
      "16": "icons/16.png",
      "32": "icons/32.png",
      "48": "icons/48.png",
      "128": "icons/128.png"
    }
  },
  "icons": {
    "16": "icons/16.png",
    "32": "icons/32.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["note.css"]
    }
  ]
}
